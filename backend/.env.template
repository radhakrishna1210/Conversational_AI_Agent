# ============================================
# QUICK START ENVIRONMENT TEMPLATE
# ============================================
# Copy this content to your `.env` file in backend/
# 
# For quick testing (with mock auth): Leave DATABASE_URL as-is
# For production (with real database): Replace DATABASE_URL with your connection string
# ============================================

# DATABASE CONFIGURATION
# Option 1: Mock Auth (No database needed) - Just leave as is
# Option 2: Real Database - Replace with your PostgreSQL connection string
# Examples:
#   DATABASE_URL="postgresql://user:password@localhost:5432/convo_ai"
#   DATABASE_URL="postgresql://user:password@host.railway.app:5432/railway"
DATABASE_URL="postgresql://postgres:password@localhost:5432/convo_ai"
# SERVER CONFIGURATION
NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:5173
CHATFLOW_PRO_URL=http://localhost:8080

# JWT SECRETS (Can use these for development)
JWT_ACCESS_SECRET=supersecretaccesskey1234567890abcdef
JWT_REFRESH_SECRET=supersecretrefreshkey1234567890xyz123

# ROLES
# Platform owner. Full access to everything, including the /admin panel.
# Everyone else is a Member. Set this to the owner's login email.
SUPER_ADMIN_EMAIL=

# SECURITY
BCRYPT_SALT_ROUNDS=12

# FILE UPLOADS
UPLOAD_DIR=uploads/

# BODY SIZE LIMIT
JSON_BODY_LIMIT=2mb

# CAMPAIGN SETTINGS (Can leave default)
CAMPAIGN_BATCH_SIZE=50
CAMPAIGN_WORKER_CONCURRENCY=2

# REDIS (Optional - needed for production queues)
# If you don't have Redis, comment this out
REDIS_URL=rediss://default:password@host:port

# META/WHATSAPP (Optional - only if integrating WhatsApp)
META_WEBHOOK_VERIFY_TOKEN=local-dev-verify-token
META_APP_ID=1234567890
META_APP_SECRET=your_app_secret
META_API_VERSION=v21.0

# SARVAM AI LLM (For multilingual chat)
# Get API key from: https://www.sarvam.ai/
# Available models: Meta-Llama-3-8B-Instruct, etc.
SARVAM_API_KEY=sk_x90ctz7s_XDdPMj4V42toISfGQMLWqL33
SARVAM_URL=https://api.sarvam.ai/api/v1
SARVAM_MODEL=Meta-Llama-3-8B-Instruct

# ENCRYPTION (Optional - for sensitive data)
ENCRYPTION_KEY=a8f3d2e1c4b7a6f5e9d8c3b2a1f0e7d6

# GOOGLE OAUTH (Optional - for Google signin)
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret

# TWILIO (Optional - for SMS/calls)
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=

# XAI GROK VOICE AGENT (Optional - bundled speech-to-speech conversational agent,
# selectable per-agent instead of the modular Voice/LLM/STT pipeline)
# Get API key from: https://x.ai/api
XAI_API_KEY=
XAI_VOICE_WS_URL=wss://api.x.ai/v1/realtime
XAI_VOICE_MODEL=grok-voice-latest
XAI_VOICE_NAME=
# Public wss:// origin Twilio can reach for two-way phone calls with a bundled
# Conversational Agent (e.g. an ngrok tunnel in dev, your real domain in
# prod). Leave blank to keep phone test calls on the existing greeting-only stub.
PUBLIC_BACKEND_WS_URL=

# ELEVENLABS CONVERSATIONAL AI (Optional - second bundled speech-to-speech
# engine, alongside xAI above). Reuses ELEVENLABS_API_KEY already configured
# for TTS. ELEVENLABS_CONVAI_AGENT_ID is a "shell" Agent you must create once
# in the ElevenLabs dashboard (elevenlabs.io/app/agents) with Prompt/First
# Message/Language overrides enabled in its Security settings.
ELEVENLABS_CONVAI_AGENT_ID=
