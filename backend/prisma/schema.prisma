generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model VoiceProvider {
  id           String    @id @default(cuid())
  name         String    @unique
  isActive     Boolean   @default(true)
  lastSyncedAt DateTime?
  voices       Voice[]

  @@index([name])
}

model Voice {
  id              String        @id @default(cuid())
  providerId      String
  providerVoiceId String
  name            String
  language        String?
  accent          String?
  gender          String?
  category        String?
  workspaceId     String?
  metadata        String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  provider        VoiceProvider @relation(fields: [providerId], references: [id])

  @@unique([providerId, providerVoiceId])
  @@index([workspaceId, category])
}

model User {
  id                    String            @id @default(cuid())
  email                 String            @unique
  passwordHash          String?
  googleId              String?           @unique
  name                  String
  avatarUrl             String?
  banned                Boolean           @default(false)
  bannedAt              DateTime?
  bannedReason          String?
  planName              String            @default("Free")
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  mobile                String?           @unique
  assignedConversations Conversation[]
  sentMessages          Message[]
  refreshTokens         RefreshToken[]
  memberships           WorkspaceMember[]
}

model Workspace {
  id                  String               @id @default(cuid())
  name                String
  slug                String               @unique
  logoUrl             String?
  metaWabaId          String?
  metaAccessToken     String?
  metaBusinessId      String?
  planName            String               @default("Starter")
  wabaId              String?
  numberAssigned      Boolean              @default(false)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  agents              Agent[]
  apiKeys             ApiKey[]
  automationFlow      AutomationFlow?
  campaigns           Campaign[]
  contacts            Contact[]
  conversations       Conversation[]
  customApiConfigs    CustomApiConfig[]
  integrations        Integration[]
  integrationLogs     IntegrationLog[]
  integrationSettings IntegrationSetting[]
  integrationTokens   IntegrationToken[]
  invoices            Invoice[]
  keywordTriggers     KeywordTrigger[]
  messages            Message[]
  notifications       Notification[]
  numberPool          NumberPool?
  oauthSessions       OAuthSession[]
  syncJobs            SyncJob[]
  templates           Template[]
  webhookConfig       WebhookConfig?
  webhookEvents       WebhookEvent[]
  whatsappNumbers     WhatsappNumber[]
  invites             WorkspaceInvite[]
  members             WorkspaceMember[]
  settings            WorkspaceSettings?
}

model WorkspaceMember {
  id          String    @id @default(cuid())
  userId      String
  workspaceId String
  role        String    @default("Viewer")
  joinedAt    DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
}

model RefreshToken {
  id          String    @id @default(cuid())
  tokenHash   String    @unique
  userId      String
  workspaceId String?
  expiresAt   DateTime
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WorkspaceInvite {
  id          String    @id @default(cuid())
  workspaceId String
  email       String
  role        String    @default("Viewer")
  token       String    @unique
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, email])
}

model WhatsappNumber {
  id                String         @id @default(cuid())
  workspaceId       String
  phoneNumber       String
  displayName       String
  category          String?
  website           String?
  description       String?
  logoUrl           String?
  metaPhoneNumberId String?
  status            String         @default("Pending")
  wabaId            String?
  accessToken       String?
  qualityRating     String?
  messagingLimit    String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  campaigns         Campaign[]
  conversations     Conversation[]
  workspace         Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, phoneNumber])
}

model ApiKey {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  keyHash     String    @unique
  keyPrefix   String
  environment String    @default("live")
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model WebhookConfig {
  id               String    @id @default(cuid())
  workspaceId      String    @unique
  url              String
  secret           String
  subscribedEvents String    @default("")
  isActive         Boolean   @default(true)
  lastPingAt       DateTime?
  lastPingStatus   Int?
  updatedAt        DateTime  @updatedAt
  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model Template {
  id              String     @id @default(cuid())
  workspaceId     String
  metaTemplateId  String?
  name            String
  category        String     @default("MARKETING")
  language        String     @default("en")
  bodyText        String
  headerText      String?
  footerText      String?
  buttons         String?    @default("")
  status          String     @default("PENDING")
  rejectionReason String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  campaigns       Campaign[]
  messages        Message[]
  workspace       Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, name, language])
}

model Contact {
  id            String              @id @default(cuid())
  workspaceId   String
  phoneNumber   String
  name          String?
  email         String?
  tags          String              @default("")
  customFields  String?             @default("")
  optedOut      Boolean             @default(false)
  optedOutAt    DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  campaigns     CampaignRecipient[]
  workspace     Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversations Conversation[]

  @@unique([workspaceId, phoneNumber])
}

model Campaign {
  id               String              @id @default(cuid())
  workspaceId      String
  name             String
  templateId       String
  whatsappNumberId String
  variableMapping  String?             @default("{}")
  botId            String?
  phoneNumbers     Json?
  csvFileName      String?
  fromNumber       String?
  progress         Int                 @default(0)
  concurrentCalls  Int                 @default(1)
  status           String              @default("DRAFT")
  scheduledAt      DateTime?
  launchedAt       DateTime?
  completedAt      DateTime?
  totalContacts    Int                 @default(0)
  sent             Int                 @default(0)
  delivered        Int                 @default(0)
  read             Int                 @default(0)
  failed           Int                 @default(0)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  template         Template            @relation(fields: [templateId], references: [id])
  whatsappNumber   WhatsappNumber      @relation(fields: [whatsappNumberId], references: [id])
  workspace        Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  recipients       CampaignRecipient[]
}

model CampaignRecipient {
  id            String    @id @default(cuid())
  campaignId    String
  contactId     String
  metaMessageId String?
  status        String    @default("pending")
  failureReason String?
  sentAt        DateTime?
  deliveredAt   DateTime?
  readAt        DateTime?
  campaign      Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact       Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([campaignId, contactId])
}

model Conversation {
  id               String         @id @default(cuid())
  workspaceId      String
  contactId        String
  whatsappNumberId String
  assignedAgentId  String?
  status           String         @default("OPEN")
  label            String?
  botEnabled       Boolean        @default(true)
  sessionExpiresAt DateTime?
  lastMessageAt    DateTime?
  unreadCount      Int            @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  assignedAgent    User?          @relation(fields: [assignedAgentId], references: [id])
  contact          Contact        @relation(fields: [contactId], references: [id])
  whatsappNumber   WhatsappNumber @relation(fields: [whatsappNumberId], references: [id])
  workspace        Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  messages         Message[]
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  workspaceId    String
  metaMessageId  String?      @unique
  direction      String       @default("OUTBOUND")
  type           String       @default("TEXT")
  body           String?
  mediaUrl       String?
  mediaCaption   String?
  templateId     String?
  templateVars   String       @default("{}")
  status         String       @default("sent")
  senderUserId   String?
  sentAt         DateTime     @default(now())
  deliveredAt    DateTime?
  readAt         DateTime?
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderUser     User?        @relation(fields: [senderUserId], references: [id])
  template       Template?    @relation(fields: [templateId], references: [id])
  workspace      Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model KeywordTrigger {
  id          String    @id @default(cuid())
  workspaceId String
  keyword     String
  replyText   String
  isActive    Boolean   @default(true)
  matchExact  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, keyword])
}

model AutomationFlow {
  id          String    @id @default(cuid())
  workspaceId String    @unique
  flowJson    String    @default("{}")
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model WorkspaceSettings {
  id                  String    @id @default(cuid())
  workspaceId         String    @unique
  timezone            String    @default("UTC")
  businessHoursJson   String?   @default("{}")
  notifyOnNewConv     Boolean   @default(true)
  notifyOnOptOut      Boolean   @default(true)
  notifyOnCampaignEnd Boolean   @default(true)
  notifyOnHighOptOut  Boolean   @default(false)
  notifyOnRateLimit   Boolean   @default(true)
  updatedAt           DateTime  @updatedAt
  workspace           Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model Invoice {
  id          String    @id @default(cuid())
  workspaceId String
  planName    String
  amountCents Int
  currency    String    @default("INR")
  status      String    @default("Paid")
  invoiceDate DateTime
  pdfUrl      String?
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model NumberPool {
  id            String     @id @default(cuid())
  phoneNumber   String     @unique
  phoneNumberId String     @unique
  wabaId        String
  accessToken   String
  displayName   String?
  status        String     @default("AVAILABLE")
  assignedTo    String?    @unique
  registeredAt  DateTime   @default(now())
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  workspace     Workspace? @relation(fields: [assignedTo], references: [id])
}

model Agent {
  id                   String    @id @default(cuid())
  workspaceId          String
  name                 String
  welcomeMessage       String
  aiModel              String
  voice                String
  transcription        String    @default("Azure")
  languages            String    @default("[]")
  flowItems            String?   @default("{}")
  maxDuration          Int       @default(30)
  silenceTimeout       Int       @default(5)
  dynamicEnabled       Boolean   @default(true)
  interruptibleEnabled Boolean   @default(true)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  settings             String    @default("{}")
  workspace            Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model Integration {
  id              String              @id @default(cuid())
  workspaceId     String
  provider        String
  name            String
  status          String              @default("disconnected")
  connected       Boolean             @default(false)
  accountId       String?
  accountLabel    String?
  lastSyncAt      DateTime?
  lastError       String?
  tokenExpiresAt  DateTime?
  webhookStatus   String              @default("not_configured")
  webhookEnabled  Boolean             @default(false)
  lastSyncedCount Int                 @default(0)
  metadata        String?             @default("{}")
  settingsJson    String              @default("{}")
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  workspace       Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  logs            IntegrationLog[]
  settings        IntegrationSetting?
  token           IntegrationToken?
  oauthSessions   OAuthSession[]
  syncJobs        SyncJob[]
  webhookEvents   WebhookEvent[]

  @@unique([workspaceId, provider])
  @@index([workspaceId, status])
}

model IntegrationToken {
  id                 String      @id @default(cuid())
  integrationId      String      @unique
  workspaceId        String
  provider           String
  accessTokenCipher  String
  refreshTokenCipher String?
  tokenType          String?
  scopes             String      @default("")
  expiresAt          DateTime?
  revokedAt          DateTime?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  integration        Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  workspace          Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, provider])
}

model IntegrationLog {
  id            String       @id @default(cuid())
  workspaceId   String
  integrationId String?
  provider      String
  level         String       @default("info")
  event         String
  message       String
  status        String?
  metadata      String?      @default("{}")
  createdAt     DateTime     @default(now())
  integration   Integration? @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  workspace     Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, provider, createdAt])
}

model OAuthSession {
  id            String       @id @default(cuid())
  workspaceId   String
  integrationId String?
  provider      String
  userId        String?
  state         String       @unique
  codeVerifier  String?
  redirectUri   String?
  expiresAt     DateTime
  consumedAt    DateTime?
  metadata      String?      @default("{}")
  createdAt     DateTime     @default(now())
  integration   Integration? @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  workspace     Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, provider])
}

model WebhookEvent {
  id               String       @id @default(cuid())
  workspaceId      String
  integrationId    String?
  provider         String
  providerEventId  String?
  eventType        String
  payload          String
  headers          String?      @default("{}")
  signatureValid   Boolean      @default(true)
  processingStatus String       @default("received")
  processedAt      DateTime?
  error            String?
  createdAt        DateTime     @default(now())
  integration      Integration? @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  workspace        Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, provider, createdAt])
}

model SyncJob {
  id            String       @id @default(cuid())
  workspaceId   String
  integrationId String?
  provider      String
  jobType       String       @default("manual")
  status        String       @default("queued")
  attempts      Int          @default(0)
  scheduledAt   DateTime?
  startedAt     DateTime?
  completedAt   DateTime?
  error         String?
  metadata      String?      @default("{}")
  createdAt     DateTime     @default(now())
  integration   Integration? @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  workspace     Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, provider, status])
}

model IntegrationSetting {
  id               String      @id @default(cuid())
  workspaceId      String
  integrationId    String      @unique
  provider         String
  settingsJson     String      @default("{}")
  enabled          Boolean     @default(true)
  webhookEnabled   Boolean     @default(false)
  selectedChannels String?     @default("[]")
  lastValidatedAt  DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  integration      Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  workspace        Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, provider])
}

model CustomApiConfig {
  id              String    @id @default(cuid())
  workspaceId     String
  name            String
  endpointUrl     String
  method          String    @default("GET")
  authType        String    @default("none")
  authValueCipher String?
  headersJson     String    @default("{}")
  queryParamsJson String    @default("{}")
  bodyTemplate    String?
  enabled         Boolean   @default(true)
  lastTestAt      DateTime?
  lastTestStatus  Int?
  lastTestError   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, name])
}

model Notification {
  id          String    @id @default(cuid())
  workspaceId String
  title       String
  message     String
  type        String    @default("INFO")
  read        Boolean   @default(false)
  details     String?
  actionText  String?
  actionLink  String?
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, read, createdAt])
}

model ContactSubmission {
  id         String   @id @default(cuid())
  name       String
  email      String
  phone      String
  callVolume String
  helpWith   String
  useCase    String
  heardAbout String?
  createdAt  DateTime @default(now())
}

model AppointmentBooking {
  id          String   @id @default(cuid())
  name        String
  email       String
  phone       String
  projectType String
  role        String
  reason      String
  callVolume  String
  userType    String
  industry    String
  useCase     String
  createdAt   DateTime @default(now())
}

model ReportIssue {
  id            String   @id @default(cuid())
  issueTitle    String
  description   String
  screenshotUrl String?
  createdAt     DateTime @default(now())
}

model VerificationToken {
  id         String    @id @default(cuid())
  email      String
  tokenHash  String
  purpose    String
  payload    String?
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([email, purpose])
}

model KbFile {
  id           String   @id @default(cuid())
  workspaceId  String
  uploadedById String
  agentId      String?
  fileName     String
  storedPath   String
  mimeType     String
  sizeBytes    Int
  textContent  String?
  createdAt    DateTime @default(now())

  @@index([workspaceId])
  @@index([workspaceId, agentId])
}

model Plan {
  id              String   @id @default(cuid())
  name            String   @unique
  priceUsd        Float
  perMinuteUsd    Float
  includedMinutes Int
  kbStorageMb     Int      @default(100)
  features        String
  active          Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Wallet {
  id           String              @id @default(cuid())
  workspaceId  String              @unique
  balanceCents Int                 @default(0)
  currency     String              @default("USD")
  updatedAt    DateTime            @updatedAt
  transactions WalletTransaction[]
}

model WalletTransaction {
  id          String   @id @default(cuid())
  walletId    String
  amountCents Int
  type        String
  note        String?
  createdById String?
  createdAt   DateTime @default(now())
  wallet      Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId, createdAt])
}

model documents {
  id          String   @id
  user_id     String
  file_name   String
  file_url    String
  uploaded_at DateTime @default(now())
}
