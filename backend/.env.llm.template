# LLM Configuration Template
# Copy this to .env and fill in your API keys

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1  # Optional: for custom OpenAI-compatible endpoints

# Azure OpenAI Configuration
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_KEY=your_azure_openai_key_here
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Google Gemini Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# Custom LLM Configuration (e.g., LLaMA)
CUSTOM_LLM_BASE_URL=http://localhost:8000  # Your custom LLM endpoint
CUSTOM_LLM_API_KEY=your_custom_llm_api_key_here

# Default LLM Provider and Model
# Options: openai, azure, gemini, custom
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o
DEFAULT_LLM_TEMPERATURE=0.7
