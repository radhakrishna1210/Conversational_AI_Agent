# Server
NODE_ENV=development
PORT=4000

# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres"

# Redis (Upstash) — optional, enables BullMQ campaign queues
REDIS_URL="rediss://:[PASSWORD]@[HOST].upstash.io:6379"

# JWT
JWT_ACCESS_SECRET=your-access-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Meta / WhatsApp Cloud API

META_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token
META_API_VERSION=v19.0
META_BUSINESS_ID=your-meta-business-id
META_SYSTEM_USER_TOKEN=your-system-user-token

# Twilio — required for scripts/sync-twilio.js
# Buys numbers from Twilio → creates a sub-WABA per number → registers on Meta Cloud API automatically
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
# Optional: set currency/timezone for sub-WABAs (defaults: USD / 1)
# WABA_CURRENCY=USD
# WABA_TIMEZONE_ID=1

# Encryption (must be exactly 32 characters)
ENCRYPTION_KEY=your-32-character-encryption-key-here

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# File uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10
JSON_BODY_LIMIT=2mb

# Security
BCRYPT_SALT_ROUNDS=12

# Campaign workers (requires REDIS_URL)
CAMPAIGN_BATCH_SIZE=50
CAMPAIGN_WORKER_CONCURRENCY=2
