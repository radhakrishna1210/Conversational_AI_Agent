# Server
NODE_ENV=development
PORT=4000

# Database (SQLite for local development)
DATABASE_URL="file:./dev.db"

# Redis (optional, enables queues and scheduled jobs)
REDIS_URL=

# JWT
JWT_ACCESS_SECRET=your-access-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Roles
# Platform owner. Full access to everything, including the /admin panel.
# Everyone else is a Member. Set this to the owner's login email.
SUPER_ADMIN_EMAIL=

# Encryption for stored integration tokens and credentials
ENCRYPTION_KEY=your-32-character-encryption-key-here

# Frontend / app URLs
CLIENT_URL=http://localhost:5173
CHATFLOW_PRO_URL=http://localhost:8080

# Uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10
JSON_BODY_LIMIT=2mb

# Security and workers
BCRYPT_SALT_ROUNDS=12
CAMPAIGN_BATCH_SIZE=50
CAMPAIGN_WORKER_CONCURRENCY=2
START_CAMPAIGN_WORKER=false

# Meta / WhatsApp Cloud API
META_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token
META_API_VERSION=v19.0
META_BUSINESS_ID=
META_SYSTEM_USER_TOKEN=

# Integration OAuth secrets
CAL_CLIENT_ID=
CAL_CLIENT_SECRET=
CAL_REDIRECT_URI=http://localhost:4000/api/v1/integrations/cal/callback

CALENDLY_CLIENT_ID=
CALENDLY_CLIENT_SECRET=
CALENDLY_REDIRECT_URI=http://localhost:4000/api/v1/integrations/calendly/callback

SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_REDIRECT_URI=http://localhost:4000/api/v1/integrations/salesforce/callback

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_AUTH_REDIRECT_URI=http://localhost:4000/api/v1/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:4000/api/v1/integrations/google_calendar/callback

SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=http://localhost:4000/api/v1/integrations/slack/callback
SLACK_SIGNING_SECRET=

HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_REDIRECT_URI=http://localhost:4000/api/v1/integrations/hubspot/callback

GENESYS_CLIENT_ID=
GENESYS_CLIENT_SECRET=
GENESYS_REDIRECT_URI=http://localhost:4000/api/v1/integrations/genesys/callback
GENESYS_REGION=mypurecloud.com

# xAI Grok Voice Agent (optional — bundled speech-to-speech engine, selectable
# per-agent as an alternative to the modular Voice/LLM/STT pipeline)
XAI_API_KEY=
XAI_VOICE_WS_URL=wss://api.x.ai/v1/realtime
XAI_VOICE_MODEL=grok-voice-latest
XAI_VOICE_NAME=
# Public wss:// origin for Twilio to reach this backend's media-stream bridge
PUBLIC_BACKEND_WS_URL=

# ElevenLabs Conversational AI (optional — second bundled speech-to-speech
# engine option, alongside xAI above). Reuses ELEVENLABS_API_KEY already
# configured for TTS. ELEVENLABS_CONVAI_AGENT_ID is a "shell" Agent you must
# create once in the ElevenLabs dashboard (Agents Platform) with Prompt/First
# Message/Language overrides enabled in its Security settings.
ELEVENLABS_CONVAI_AGENT_ID=

# Optional API base overrides
CAL_API_BASE_URL=https://api.cal.com
CALENDLY_API_BASE_URL=https://api.calendly.com
SALESFORCE_INSTANCE_URL=
GOOGLE_API_BASE_URL=https://www.googleapis.com
SLACK_API_BASE_URL=https://slack.com/api
HUBSPOT_API_BASE_URL=https://api.hubapi.com
GENESYS_API_BASE_URL=
